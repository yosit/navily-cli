{
  "name": "dripline-plugin-navily",
  "version": "0.1.0",
  "description": "navily.com plugin for dripline — query marinas, anchorages, weather, reviews, regions, bookings as SQL tables",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "dripline",
    "plugin",
    "navily",
    "marina",
    "anchorage",
    "sailing",
    "weather"
  ],
  "license": "MIT",
  "author": "yosit",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "dripline": ">=0.9.0"
  },
  "dependencies": {
    "@yosit/navily-cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dripline": "^0.9.16",
    "typescript": "^5.6.3"
  }
}
