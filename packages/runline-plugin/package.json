{
  "name": "@yosit/runline-plugin-navily",
  "version": "0.3.2",
  "description": "navily.com plugin for runline — callable actions for marinas, anchorages, reviews, bookings, weather",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "runline",
    "plugin",
    "navily",
    "marina",
    "anchorage",
    "sailing",
    "agent"
  ],
  "license": "MIT",
  "author": "yosit",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "runline": ">=0.7.0"
  },
  "dependencies": {
    "@yosit/navily-cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "runline": "^0.7.5",
    "typescript": "^5.6.3"
  }
}
